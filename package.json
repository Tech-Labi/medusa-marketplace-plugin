    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.15.2",
    "@medusajs/cli": "^2.15.2",
    "@medusajs/framework": "^2.15.2",
    "@medusajs/medusa": "^2.15.2",
    "@medusajs/test-utils": "^2.15.2"
  },
  "engines": {
    "node": ">=20"
  },
