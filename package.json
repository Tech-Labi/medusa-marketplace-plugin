    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.15.2",
    "@medusajs/cli": "^2.15.2",
    "@medusajs/framework": "^2.15.2",
    "@medusajs/medusa": "^2.15.2",
    "@medusajs/test-utils": "^2.15.2",
    "@medusajs/ui": "^4.1.9",
